# Download profile: public | workflow | all
MODEL_PROFILE=workflow
DOWNLOAD_CONCURRENCY=5
DOWNLOAD_CONNECTIONS=16
DOWNLOAD_MAX_TRIES=10
NODE_CLONE_CONCURRENCY=6
ALLOW_MISSING_MODEL_URLS=0
SKIP_MODEL_DOWNLOAD=0

# RunPod secrets should be referenced in the template, not committed.
HF_TOKEN=
CIVITAI_TOKEN=

# Direct file/API-download URLs for LoRAs whose source URLs are not embedded
# in the workflow. Civitai format: https://civitai.com/api/download/models/<VERSION_ID>
MODEL_URL_DR34ML4Y=
MODEL_URL_CREAMPIE=
MODEL_URL_PENIS_LORA=
MODEL_URL_DEEPTHROAT=
MODEL_URL_LIQUID_WET=

# Required only when MODEL_PROFILE=all.
MODEL_URL_LTX23_NSFW_FURRY=
MODEL_URL_CUM_SHOT=
MODEL_URL_TITFUCK=
MODEL_URL_ORGASM=

COMFY_PORT=8188
# Example for 24 GB cards; leave blank on 48 GB+ unless needed.
COMFY_ARGS=

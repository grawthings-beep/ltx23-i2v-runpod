# Download profile: public | workflow | all
MODEL_PROFILE=workflow
DOWNLOAD_CONCURRENCY=5
DOWNLOAD_CONNECTIONS=16
DOWNLOAD_MAX_TRIES=10
NODE_CLONE_CONCURRENCY=6
ALLOW_MISSING_MODEL_URLS=0
SKIP_MODEL_DOWNLOAD=0

# RunPod secrets should be selected with the key icon, not committed.
# HF_TOKEN is used for Hugging Face downloads. CIVITAI_TOKEN remains supported
# by the downloader but is not required by the current V6.1 manifest.
HF_TOKEN=
CIVITAI_TOKEN=

COMFY_PORT=8188
# Leave blank on an A40; add --lowvram only when troubleshooting smaller GPUs.
COMFY_ARGS=

{
  "name": "ltx23-i2v-comfyui",
  "container_image": "ghcr.io/grawthings-beep/ltx23-i2v-runpod:latest",
  "container_disk_gb": 35,
  "volume_mount_path": "/workspace",
  "recommended_network_volume_gb": 250,
  "http_ports": [
    {
      "label": "ComfyUI",
      "port": 8188
    }
  ],
  "environment_variables": {
    "MODEL_PROFILE": "workflow",
    "DOWNLOAD_CONCURRENCY": "5",
    "DOWNLOAD_CONNECTIONS": "16",
    "ALLOW_MISSING_MODEL_URLS": "0",
    "COMFY_PORT": "8188",
    "COMFY_ARGS": "",
    "DOWNLOAD_MAX_TRIES": "10",
    "NODE_CLONE_CONCURRENCY": "6"
  },
  "secret_references": {
    "HF_TOKEN": "{{ RUNPOD_SECRET_huggingface_token }}",
    "CIVITAI_TOKEN": "{{ RUNPOD_SECRET_civitai_token }}"
  },
  "gpu_guidance": {
    "recommended": "48 GB VRAM or more",
    "24_gb_note": "Start with shorter duration and lower longer-side resolution; add --lowvram through COMFY_ARGS if necessary."
  }
}
